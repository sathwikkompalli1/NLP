# IQAS Environment Configuration
# Copy to .env and customize

# Model Configuration
IQAS_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
IQAS_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Chunking
IQAS_CHUNK_SIZE=512
IQAS_CHUNK_OVERLAP=50

# Retrieval
IQAS_TOP_K_RETRIEVE=20
IQAS_TOP_K_RERANK=5

# Logging
IQAS_LOG_LEVEL=INFO
